class Stack:
    def __init__(self):
        self.l = []
    def push(self, a):
        self.l.append(a)
    def pop(self):
        self.l.pop()
    def display(self):
        print("->".join(map(str, self.l)))
    def peek(self):
        print(self.l[-1])
s = Stack()
s.push(100)
s.push(90)
s.push(47)
s.push(49)
s.pop()
s.display()
s.peek()
